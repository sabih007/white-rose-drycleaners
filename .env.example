# Postgres connection string (Vercel Marketplace -> Neon/Prisma Postgres, etc.)
DATABASE_URL=""

# Shared password to access the portal.
APP_PASSWORD=""
# Random secret used to sign login sessions, e.g: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=""
# Shown in WhatsApp messages and on the receipt.
SHOP_NAME="Your Dry Cleaner"
# Prefix used for human-readable booking numbers, e.g. WRD-00001.
BOOKING_PREFIX="WRD"
# Country code (no +) used to fill in local-format phone numbers for WhatsApp.
DEFAULT_COUNTRY_CODE="92"

# Twilio WhatsApp (leave TWILIO_WHATSAPP_NUMBER blank to disable; bookings still save fine)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_NUMBER=""
