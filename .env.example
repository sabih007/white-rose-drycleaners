# Postgres connection string (Vercel Marketplace -> Neon/Prisma Postgres, etc.)
DATABASE_URL=""

# Shared password to access the portal.
APP_PASSWORD=""
# Random secret used to sign login sessions, e.g: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=""
# Shown in SMS messages and on the receipt.
SHOP_NAME="Your Dry Cleaner"
# Prefix used for human-readable booking numbers, e.g. WRD-00001.
BOOKING_PREFIX="WRD"

# Twilio SMS (leave blank to disable SMS; bookings still save fine)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""
